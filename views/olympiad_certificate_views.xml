<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Certificate Views -->
        
        <!-- List View -->
        <record id="view_olympiad_certificate_list" model="ir.ui.view">
            <field name="name">sp.olympiad.certificate.list</field>
            <field name="model">sp_olympiad.certificate</field>
            <field name="arch" type="xml">
                <list string="Certificates">
                    <field name="certificate_number"/>
                    <field name="student_id"/>
                    <field name="project_id"/>
                    <field name="certificate_type"/>
                    <field name="year"/>
                    <field name="issue_date"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_olympiad_certificate_form" model="ir.ui.view">
            <field name="name">sp.olympiad.certificate.form</field>
            <field name="model">sp_olympiad.certificate</field>
            <field name="arch" type="xml">
                <form string="Certificate">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="certificate_number"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="student_id"/>
                                <field name="project_id"/>
                                <field name="certificate_type"/>
                                <field name="year"/>
                                <field name="issue_date"/>
                            </group>
                            <group>
                                <field name="pdf_file" filename="pdf_filename"/>
                            </group>
                        </group>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_olympiad_certificate_search" model="ir.ui.view">
            <field name="name">sp.olympiad.certificate.search</field>
            <field name="model">sp_olympiad.certificate</field>
            <field name="arch" type="xml">
                <search>
                    <field name="certificate_number"/>
                    <field name="student_id"/>
                    <field name="project_id"/>
                    <field name="certificate_type"/>
                    <field name="year"/>
                    <filter string="Participation" name="type_participation" domain="[('certificate_type', '=', 'participation')]"/>
                    <filter string="Gold" name="type_gold" domain="[('certificate_type', '=', 'gold')]"/>
                    <filter string="Silver" name="type_silver" domain="[('certificate_type', '=', 'silver')]"/>
                    <filter string="Bronze" name="type_bronze" domain="[('certificate_type', '=', 'bronze')]"/>
                    <filter string="Honorable Mention" name="type_hm" domain="[('certificate_type', '=', 'honorable_mention')]"/>
                    <separator/>
                    <filter string="2025" name="year_2025" domain="[('year', '=', 2025)]"/>
                    <filter string="2026" name="year_2026" domain="[('year', '=', 2026)]"/>
                    <filter string="2027" name="year_2027" domain="[('year', '=', 2027)]"/>
                    <group>
                        <filter string="Certificate Type" name="group_type" context="{'group_by': 'certificate_type'}"/>
                        <filter string="Year" name="group_year" context="{'group_by': 'year'}"/>
                        <filter string="Student" name="group_student" context="{'group_by': 'student_id'}"/>
                        <filter string="Project" name="group_project" context="{'group_by': 'project_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_olympiad_certificate" model="ir.actions.act_window">
            <field name="name">Certificates</field>
            <field name="res_model">sp_olympiad.certificate</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    No certificates found.
                </p>
                <p>
                    Certificates are automatically generated when projects are finished.
                    Each student receives a participation certificate, and medal certificates
                    are awarded based on project evaluation results.
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_olympiad_certificates"
                  name="Certificates"
                  parent="menu_olympiad_config"
                  action="action_olympiad_certificate"
                  sequence="50"
                  groups="sp_olympiad.group_sp_olympiad_admin,sp_olympiad.group_sp_olympiad_staff"/>
    </data>
</odoo>
