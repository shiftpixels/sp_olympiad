<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Custom Paper Format (2.5 cm margins) -->
    <record id="paperformat_olympiad_standard" model="report.paperformat">
        <field name="name">Olympiad Standard (Portrait, 1cm Margins)</field>
        <field name="default" eval="True"/>
        <field name="format">A4</field>
        <field name="orientation">Portrait</field>
        <field name="margin_top">20</field>
        <field name="margin_bottom">10</field>
        <field name="margin_left">20</field>
        <field name="margin_right">8</field>
        <field name="header_line" eval="False"/>
        <field name="header_spacing">5</field>
        <field name="dpi">90</field>
    </record>

    <!-- Report Action -->
    <record id="action_report_category_criteria" model="ir.actions.report">
        <field name="name">Evaluation Criteria</field>
        <field name="model">sp_olympiad.category</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">sp_olympiad.report_category_criteria_template</field>
        <field name="report_file">sp_olympiad.report_category_criteria_template</field>
        <field name="print_report_name">'Evaluation_Criteria_%s' % (object.name)</field>
        <field name="binding_model_id" ref="model_sp_olympiad_category"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="paperformat_olympiad_standard"/>
    </record>

    <!-- PDF Template -->
    <template id="report_category_criteria_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="o">
                <t t-call="web.basic_layout">
                    <div class="page">
                        <style>
                            .page {
                                font-family: 'Helvetica', 'Arial', sans-serif !important;
                                color: #333 !important;
                            }
                            .page table {
                                border: 1px solid #000 !important;
                                border-collapse: collapse !important;
                                width: 100% !important;
                                margin-bottom: 10px !important;
                                table-layout: auto !important;
                                page-break-inside: avoid !important;
                                font-size: 0.75rem !important; /* Reduced from 0.85rem */
                            }
                            .page table td, .page table th {
                                border: 1px solid #000 !important;
                                padding: 4px 6px !important; /* More compact padding */
                                vertical-align: top !important;
                                word-wrap: break-word !important;
                            }
                            .page table th {
                                background-color: #f2f2f2 !important;
                                font-weight: bold !important;
                                text-transform: uppercase !important;
                                font-size: 0.7rem !important;
                                border-bottom: 2px solid #000 !important;
                            }
                            /* Force images in criteria to stay small */
                            .page .criteria-content img {
                                max-width: 250px !important; /* Limit image width */
                                height: auto !important;
                                display: block;
                                margin: 5px 0;
                            }
                        </style>
                        <div class="text-center mb-4">
                            <h2 class="fw-bold text-uppercase" style="letter-spacing: 1px;">Olympiad Evaluation Criteria</h2>
                            <hr />
                        </div>

                        <div class="row mb-4">
                            <div class="col-12 border-bottom pb-2">
                                <h3 class="fw-bold" style="color: #0056b3;">
                                    <span t-field="o.name"/> 
                                    <small class="text-muted" style="font-size: 0.6em;">[<span t-field="o.code"/>]</small>
                                </h3>
                            </div>
                        </div>

                        <div class="mt-2 criteria-content">
                            <div class="prose" t-field="o.criteria"/>
                        </div>
                    </div>
                </t>
            </t>
        </t>
    </template>
</odoo>
