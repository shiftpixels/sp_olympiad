<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- Website Menu -->
    <record id="menu_olympiad_categories" model="website.menu">
        <field name="name">Categories</field>
        <field name="url">/olympiad/categories</field>
        <field name="parent_id" ref="website.main_menu"/>
        <field name="sequence" type="int">20</field>
    </record>

    <!-- Categories List Page -->
    <template id="categories_page" name="Olympiad Categories">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_title pt48 pb24" data-snippet="s_title">
                    <div class="container">
                        <div class="row s_nb_column_fixed">
                            <div class="col-lg-12 s_title_default_extra">
                                <h1 style="text-align: center;">Olympiad Categories</h1>
                                <p class="lead" style="text-align: center;">Explore the diverse scientific fields of our Olympiad.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="s_dynamic_snippet_products pb48 pt24">
                    <div class="container">
                        <div class="row">
                            <t t-foreach="categories" t-as="category">
                                <div class="col-lg-4 col-md-6 mb-4">
                                    <div class="card h-100 shadow-sm border-0 transition-base hvr-shadow">
                                        <a t-attf-href="/olympiad/category/#{slug(category)}">
                                            <img t-if="category.image" t-attf-src="/web/image/sp_olympiad.category/#{category.id}/image" class="card-img-top" style="height: 200px; object-fit: cover;" t-att-alt="category.name"/>
                                            <div t-else="" class="card-img-top bg-secondary d-flex align-items-center justify-content-center" style="height: 200px;">
                                                <i class="fa fa-flask fa-4x text-white-50"></i>
                                            </div>
                                        </a>
                                        <div class="card-body text-center">
                                            <h5 class="card-title fw-bold mb-1">
                                                <a t-attf-href="/olympiad/category/#{slug(category)}" class="text-decoration-none text-dark">
                                                    <span t-field="category.name"/>
                                                </a>
                                            </h5>
                                            <div class="text-primary small fw-bold mb-0">
                                                <t t-out="category.code"/>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- Category Detail Page -->
    <template id="category_detail_page" name="Category Details">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="pt32 pb16">
                    <div class="container">
                        <nav aria-label="breadcrumb">
                            <ol class="breadcrumb bg-transparent p-0">
                                <li class="breadcrumb-item"><a href="/">Home</a></li>
                                <li class="breadcrumb-item"><a href="/olympiad/categories">Categories</a></li>
                                <li class="breadcrumb-item active" aria-current="page"><span t-field="category.name"/></li>
                            </ol>
                        </nav>
                    </div>
                </section>

                <section class="pb48">
                    <div class="container">
                        <!-- Top: Large Centered Image -->
                        <div class="row justify-content-center mb-5">
                            <div class="col-lg-10 text-center">
                                <img t-if="category.image" t-attf-src="/web/image/sp_olympiad.category/#{category.id}/image" class="img-fluid rounded shadow-lg w-100" style="max-height: 500px; object-fit: cover;" t-att-alt="category.name"/>
                                <div t-else="" class="bg-light rounded shadow-sm d-flex align-items-center justify-content-center" style="height: 300px;">
                                    <i class="fa fa-flask fa-5x text-muted opacity-25"></i>
                                </div>
                            </div>
                        </div>

                        <!-- Bottom: Content Section -->
                        <div class="row justify-content-center">
                            <div class="col-lg-10">
                                <div class="text-center mb-5">
                                    <span class="badge text-bg-primary mb-2 px-3 py-2 rounded-pill">Category Code: <t t-out="category.code"/></span>
                                    <h1 class="display-3 fw-bold mb-4" t-field="category.name"/>
                                    <hr class="w-25 mx-auto border-primary border-2 opacity-50"/>
                                </div>
                                
                                <div class="nav-tabs-wrapper mb-4">
                                    <ul class="nav nav-pills justify-content-center mb-4" id="categoryTabs" role="tablist">
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link active fw-bold px-4 py-2" id="desc-tab" data-bs-toggle="tab" data-bs-target="#description" type="button" role="tab">Description</button>
                                        </li>
                                        <li class="nav-item" role="presentation">
                                            <button class="nav-link fw-bold px-4 py-2 ms-2" id="criteria-tab" data-bs-toggle="tab" data-bs-target="#criteria" type="button" role="tab">Evaluation Criteria</button>
                                        </li>
                                    </ul>
                                </div>

                                <div class="tab-content bg-white p-4 rounded shadow-sm border" id="categoryTabsContent">
                                    <div class="tab-pane fade show active" id="description" role="tabpanel">
                                        <div class="prose max-w-none text-muted" style="font-size: 1.1rem; line-height: 1.8;" t-field="category.description"/>
                                    </div>
                                    <div class="tab-pane fade" id="criteria" role="tabpanel">
                                        <div class="p-3">
                                            <div class="d-flex justify-content-between align-items-center mb-4">
                                                <h4 class="text-primary fw-bold mb-0"><i class="fa fa-check-circle me-2"></i>What we evaluate:</h4>
                                                <a t-attf-href="/report/pdf/sp_olympiad.action_report_category_criteria/#{category.id}" class="btn btn-outline-danger btn-sm rounded-pill shadow-sm transition-base">
                                                    <i class="fa fa-file-pdf-o me-1"></i> Download as PDF
                                                </a>
                                            </div>
                                            <div class="prose max-w-none text-dark" style="font-size: 1.1rem;" t-field="category.criteria"/>
                                        </div>
                                    </div>
                                </div>
                                
                                <div class="mt-5 text-center">
                                    <a href="/olympiad/categories" class="btn btn-link text-decoration-none text-muted">
                                        <i class="fa fa-chevron-left me-1"></i> Back to All Categories
                                    </a>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- Mentor Signup Page -->
    <template id="mentor_signup_page" name="Mentor Registration">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="pt32 pb24">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-6">
                                <div class="card shadow-sm border-0">
                                    <div class="card-header bg-primary text-white text-center py-3">
                                        <h3 class="mb-0 fw-bold">Register as Mentor</h3>
                                        <p class="mb-0 text-muted">Join our team of Olympiad mentors</p>
                                    </div>
                                    <div class="card-body p-4">
                                        <!-- Success Message -->
                                        <t t-if="success">
                                            <div class="alert alert-success alert-dismissible fade show" role="alert">
                                                <strong>Success!</strong>
                                                <span t-out="success_message or 'Your registration has been submitted. Please check your email to verify your account.'"/>
                                                <button t-attf-type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                            </div>
                                        </t>

                                        <!-- Error Message -->
                                        <t t-if="error">
                                            <div class="alert alert-danger alert-dismissible fade show" role="alert">
                                                <strong>Error:</strong> <span t-out="error"/>
                                                <button t-attf-type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
                                            </div>
                                        </t>

                                        <form t-attf-action="/mentor/submit" method="post" class="mt-4">
                                            <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>

                                            <!-- Name -->
                                            <div class="mb-3">
                                                <label for="name" class="form-label fw-bold">Full Name *</label>
                                                <input type="text" id="name" name="name" class="form-control"
                                                       t-attf-value="{{form_data.name if form_data else ''}}" required="required"/>
                                            </div>

                                            <!-- Email -->
                                            <div class="mb-3">
                                                <label for="email" class="form-label fw-bold">Email Address *</label>
                                                <input type="email" id="email" name="email" class="form-control"
                                                       t-attf-value="{{form_data.email if form_data else ''}}" required="required"/>
                                                <div class="form-text">We'll never share your email with anyone else.</div>
                                            </div>

                                            <!-- Password -->
                                            <div class="mb-3">
                                                <label for="password" class="form-label fw-bold">Password *</label>
                                                <input type="password" id="password" name="password" class="form-control" required="required"/>
                                                <div class="form-text">Minimum 8 characters</div>
                                            </div>

                                            <!-- Country -->
                                            <div class="mb-3">
                                                <label for="country_id" class="form-label fw-bold">Country</label>
                                                <select id="country_id" name="country_id" class="form-select">
                                                    <option value="">Select your country</option>
                                                    <t t-foreach="countries" t-as="country">
                                                        <option t-attf-value="{{country.id}}"
                                                                t-att-selected="form_data and form_data.get('country_id') == country.id and 'selected' or None">
                                                            <span t-field="country.name"/>
                                                        </option>
                                                    </t>
                                                </select>
                                            </div>

                                            <!-- Branch -->
                                            <div class="mb-3">
                                                <label for="branch" class="form-label fw-bold">Field / Branch</label>
                                                <input type="text" id="branch" name="branch" class="form-control"
                                                       t-attf-value="{{form_data.branch if form_data else ''}}"
                                                       placeholder="e.g., Physics, Mathematics, Biology"/>
                                                <div class="form-text">Your area of expertise</div>
                                            </div>

                                            <!-- Phone -->
                                            <div class="mb-3">
                                                <label for="phone" class="form-label fw-bold">Phone Number</label>
                                                <input type="tel" id="phone" name="phone" class="form-control"
                                                       t-attf-value="{{form_data.phone if form_data else ''}}"
                                                       placeholder="+1234567890"/>
                                            </div>

                                            <!-- WhatsApp -->
                                            <div class="mb-3">
                                                <label for="whatsapp" class="form-label fw-bold">WhatsApp</label>
                                                <input type="tel" id="whatsapp" name="whatsapp" class="form-control"
                                                       t-attf-value="{{form_data.whatsapp if form_data else ''}}"
                                                       placeholder="+1234567890"/>
                                                <div class="form-text">For quick communication</div>
                                            </div>

                                            <!-- Submit -->
                                            <div class="d-grid gap-2 mt-4">
                                                <button type="submit" class="btn btn-primary btn-lg">
                                                    Register as Mentor
                                                </button>
                                            </div>

                                            <div class="text-center mt-3">
                                                <small class="text-muted">
                                                    Already have an account? <a href="/web" class="text-decoration-none">Log in</a>
                                                </small>
                                            </div>
                                        </form>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- Mentor Verify Page -->
    <template id="mentor_verify_page" name="Email Verification">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="pt32 pb24">
                    <div class="container">
                        <div class="row justify-content-center">
                            <div class="col-lg-6">
                                <div class="card shadow-sm border-0">
                                    <div class="card-header bg-primary text-white text-center py-3">
                                        <h3 class="mb-0 fw-bold">Verify Your Email</h3>
                                    </div>
                                    <div class="card-body p-4 text-center">
                                        <t t-if="success">
                                            <div class="mb-4">
                                                <i class="fa fa-check-circle fa-4x text-success"></i>
                                            </div>
                                            <h4 class="text-success fw-bold mb-3">Email Verified!</h4>
                                            <p class="text-muted" t-out="message"/>
                                        </t>
                                        <t t-elif="error">
                                            <div class="mb-4">
                                                <i class="fa fa-exclamation-circle fa-4x text-danger"></i>
                                            </div>
                                            <h4 class="text-danger fw-bold mb-3">Verification Failed</h4>
                                            <p class="text-muted" t-out="error"/>
                                            <t t-if="mentor">
                                                <div class="mt-3">
                                                    <a t-attf-href="/mentor/resend-verify"
                                                       class="btn btn-outline-primary btn-sm"
                                                       onclick="document.getElementById('resend_form').submit();">
                                                        Resend Verification Email
                                                    </a>
                                                    <form t-attf-id="resend_form" t-attf-action="/mentor/resend-verify" method="post" style="display:none;">
                                                        <input type="hidden" name="email" t-att-value="mentor.email"/>
                                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                                    </form>
                                                </div>
                                            </t>
                                        </t>
                                        <div class="mt-4">
                                            <a href="/web/login" class="btn btn-primary">
                                                Go to Login
                                            </a>
                                        </div>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>

    <!-- My Olympiad Dashboard -->
    <template id="my_olympiad_dashboard" name="My Olympiad Dashboard">
        <t t-call="website.layout">
            <div id="wrap" class="oe_structure oe_empty">
                <section class="s_title pt48 pb24">
                    <div class="container">
                        <div class="row s_nb_column_fixed">
                            <div class="col-lg-12 text-center">
                                <h1>Welcome to Olympiad Portal</h1>
                                <p class="lead">This is your personal dashboard.</p>
                            </div>
                        </div>
                    </div>
                </section>

                <section class="s_features pb48 pt24">
                    <div class="container">
                        <div class="row">
                            <div class="col-lg-4 mb-4">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-body text-center">
                                        <i class="fa fa-list fa-3x text-primary mb-3"></i>
                                        <h4 class="card-title fw-bold">My Categories</h4>
                                        <p class="card-text text-muted">Explore and manage Olympiad categories.</p>
                                        <a href="/olympiad/categories" class="btn btn-outline-primary btn-sm">Go to Categories</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 mb-4">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-body text-center">
                                        <i class="fa fa-user fa-3x text-primary mb-3"></i>
                                        <h4 class="card-title fw-bold">Profile</h4>
                                        <p class="card-text text-muted">Manage your mentor profile.</p>
                                        <a href="/web#action=sp_olympiad.mentor_action" class="btn btn-outline-primary btn-sm">View Profile</a>
                                    </div>
                                </div>
                            </div>
                            <div class="col-lg-4 mb-4">
                                <div class="card h-100 shadow-sm border-0">
                                    <div class="card-body text-center">
                                        <i class="fa fa-sign-out fa-3x text-primary mb-3"></i>
                                        <h4 class="card-title fw-bold">Logout</h4>
                                        <p class="card-text text-muted">Sign out from your account.</p>
                                        <a href="/web/session/logout" class="btn btn-outline-danger btn-sm">Logout</a>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </section>
            </div>
        </t>
    </template>
</odoo>
