<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Student Views -->
        
        <!-- List View -->
        <record id="view_olympiad_student_list" model="ir.ui.view">
            <field name="name">sp.olympiad.student.list</field>
            <field name="model">sp_olympiad.student</field>
            <field name="arch" type="xml">
                <list string="Students">
                    <field name="name"/>
                    <field name="age"/>
                    <field name="gender"/>
                    <field name="country_id"/>
                    <field name="tshirt_size"/>
                    <field name="visa_required"/>
                    <field name="excursion"/>
                    <field name="accommodation_nights"/>
                    <field name="mentor_id"/>
                </list>
            </field>
        </record>

        <!-- Form View -->
        <record id="view_olympiad_student_form" model="ir.ui.view">
            <field name="name">sp.olympiad.student.form</field>
            <field name="model">sp_olympiad.student</field>
            <field name="arch" type="xml">
                <form string="Student">
                    <sheet>
                        <div class="oe_title">
                            <h1>
                                <field name="name" readonly="1"/>
                            </h1>
                        </div>
                        <group>
                            <group>
                                <field name="first_name"/>
                                <field name="last_name"/>
                                <field name="birth_date"/>
                                <field name="age" readonly="1"/>
                                <field name="gender"/>
                                <field name="country_id"/>
                            </group>
                            <group>
                                <field name="email"/>
                                <field name="phone"/>
                                <field name="visa_required"/>
                                <field name="tshirt_size"/>
                            </group>
                        </group>
                        <notebook>
                            <page string="Dietary Information">
                                <group>
                                    <field name="allergies" nolabel="1"/>
                                    <field name="dietary_restrictions" nolabel="1"/>
                                </group>
                            </page>
                            <page string="Accommodation">
                                <group>
                                    <field name="no_accommodation"/>
                                    <field name="accommodation_ids" widget="many2many_tags" 
                                           invisible="no_accommodation"/>
                                    <field name="accommodation_nights" readonly="1"/>
                                </group>
                            </page>
                        </notebook>
                    </sheet>
                    <chatter/>
                </form>
            </field>
        </record>

        <!-- Search View -->
        <record id="view_olympiad_student_search" model="ir.ui.view">
            <field name="name">sp.olympiad.student.search</field>
            <field name="model">sp_olympiad.student</field>
            <field name="arch" type="xml">
                <search>
                    <field name="name"/>
                    <field name="first_name"/>
                    <field name="last_name"/>
                    <field name="country_id"/>
                    <field name="project_ids"/>
                    <field name="gender"/>
                    <field name="tshirt_size"/>
                    <field name="mentor_id"/>
                    <filter string="Visa Required" name="visa_required" domain="[('visa_required', '=', True)]"/>
                    <filter string="No Accommodation" name="no_accommodation" domain="[('no_accommodation', '=', True)]"/>
                    <separator/>
                    <filter string="Male" name="gender_male" domain="[('gender', '=', 'M')]"/>
                    <filter string="Female" name="gender_female" domain="[('gender', '=', 'F')]"/>
                    <filter string="Diverse" name="gender_diverse" domain="[('gender', '=', 'D')]"/>
                    <group>
                        <filter string="Gender" name="group_gender" context="{'group_by': 'gender'}"/>
                        <filter string="Country" name="group_country" context="{'group_by': 'country_id'}"/>
                        <filter string="T-Shirt Size" name="group_tshirt" context="{'group_by': 'tshirt_size'}"/>
                        <filter string="Mentor" name="group_mentor" context="{'group_by': 'mentor_id'}"/>
                    </group>
                </search>
            </field>
        </record>

        <!-- Action -->
        <record id="action_olympiad_student" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">sp_olympiad.student</field>
            <field name="view_mode">list,form</field>
            <field name="help" type="html">
                <p class="o_view_nocontent_smiling_face">
                    Create your first student!
                </p>
                <p>
                    Students are participants in Olympiad projects. Each student belongs to a mentor
                    and can have accommodation, dietary requirements, and other logistics information.
                </p>
            </field>
        </record>

        <!-- Menu Item -->
        <menuitem id="menu_olympiad_students"
                  name="Students"
                  parent="menu_olympiad_config"
                  action="action_olympiad_student"
                  sequence="40"
                  groups="sp_olympiad.group_sp_olympiad_admin,sp_olympiad.group_sp_olympiad_staff"/>
    </data>
</odoo>
