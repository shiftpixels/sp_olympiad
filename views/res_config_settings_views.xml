<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Settings Action -->
        <record id="action_sp_olympiad_config_settings" model="ir.actions.act_window">
            <field name="name">Settings</field>
            <field name="res_model">res.config.settings</field>
            <field name="view_mode">form</field>
            <field name="target">current</field>
            <field name="context">{"module": "sp_olympiad"}</field>
        </record>

        <!-- Settings View Inheritance -->
        <record id="view_res_config_settings_form_inherit" model="ir.ui.view">
            <field name="name">res.config.settings.view.form.inherit.sp_olympiad</field>
            <field name="model">res.config.settings</field>
            <field name="priority" eval="100"/>
            <field name="inherit_id" ref="base.res_config_settings_view_form"/>
            <field name="arch" type="xml">
                <xpath expr="//form" position="inside">
                    <app data-string="Olympiad" string="Olympiad" name="sp_olympiad" groups="base.group_system">
                        <block title="General Settings" name="olympiad_general_settings">
                            <setting string="Competition Name" help="Set the official name of the competition." config_parameter="sp_olympiad.olympiad_name">
                                <field name="olympiad_name" placeholder="e.g. International Biology Olympiad"/>
                            </setting>
                            <setting string="Category Max Participants Limit" help="Upper limit used to validate category Max Participants." config_parameter="sp_olympiad.category_max_participants_limit">
                                <field name="category_max_participants_limit"/>
                            </setting>
                        </block>
                        <block title="Mentor Signup" name="olympiad_mentor_signup">
                            <setting string="Enable Mentor Signup" help="Allow external users to register as mentors via the mentor signup form." config_parameter="sp_olympiad.mentor_signup_enabled">
                                <field name="mentor_signup_enabled" string="Enable Mentor Signup"/>
                            </setting>
                            <setting string="Require Email Verification" help="Require mentors to verify their email before account becomes active." config_parameter="sp_olympiad.mentor_verification_enabled">
                                <field name="mentor_verification_enabled" string="Require Email Verification"/>
                            </setting>
                        </block>
                        <block title="Rate Limiting" name="olympiad_rate_limiting">
                            <div class="row mt16" name="rate_limiting_header">
                                <div class="col-lg-12">
                                    <div class="alert alert-info">
                                        Configure rate limiting for security purposes. These settings help prevent brute force attacks and abuse.
                                    </div>
                                </div>
                            </div>
                            <div class="row mt16" name="rate_limiting_login">
                                <div class="col-12">
                                    <h4>Login Rate Limiting</h4>
                                </div>
                            </div>
                            <div class="row mt8" name="rate_limiting_login_fields">
                                <div class="col-4">
                                    <label for="login_rate_limit_window" class="col-form-label">Window (seconds)</label>
                                    <field name="login_rate_limit_window" class="oe_inline"/>
                                </div>
                                <div class="col-4">
                                    <label for="login_rate_limit_ip" class="col-form-label">IP Limit</label>
                                    <field name="login_rate_limit_ip" class="oe_inline"/>
                                </div>
                                <div class="col-4">
                                    <label for="login_rate_limit_email" class="col-form-label">Email Limit</label>
                                    <field name="login_rate_limit_email" class="oe_inline"/>
                                </div>
                            </div>
                            <div class="row mt16" name="rate_limiting_signup">
                                <div class="col-12">
                                    <h4>Signup Rate Limiting</h4>
                                </div>
                            </div>
                            <div class="row mt8" name="rate_limiting_signup_fields">
                                <div class="col-4">
                                    <label for="signup_rate_limit_window" class="col-form-label">Window (seconds)</label>
                                    <field name="signup_rate_limit_window" class="oe_inline"/>
                                </div>
                                <div class="col-4">
                                    <label for="signup_rate_limit_ip" class="col-form-label">IP Limit</label>
                                    <field name="signup_rate_limit_ip" class="oe_inline"/>
                                </div>
                                <div class="col-4">
                                    <label for="signup_rate_limit_email" class="col-form-label">Email Limit</label>
                                    <field name="signup_rate_limit_email" class="oe_inline"/>
                                </div>
                            </div>
                            <div class="row mt16" name="rate_limiting_resend">
                                <div class="col-12">
                                    <h4>Resend Verification Rate Limiting</h4>
                                </div>
                            </div>
                            <div class="row mt8" name="rate_limiting_resend_fields">
                                <div class="col-4">
                                    <label for="resend_rate_limit_window" class="col-form-label">Window (seconds)</label>
                                    <field name="resend_rate_limit_window" class="oe_inline"/>
                                </div>
                                <div class="col-4">
                                    <label for="resend_rate_limit_ip" class="col-form-label">IP Limit</label>
                                    <field name="resend_rate_limit_ip" class="oe_inline"/>
                                </div>
                                <div class="col-4">
                                    <label for="resend_rate_limit_email" class="col-form-label">Email Limit</label>
                                    <field name="resend_rate_limit_email" class="oe_inline"/>
                                </div>
                            </div>
                         </block>
                         <block title="Demo Data" name="olympiad_demo_data">
                             <div class="row mt16" name="demo_data_header">
                                 <div class="col-lg-12">
                                     <div class="alert alert-warning">
                                         Load or clear demo data for testing purposes. This will create sample categories, events, and mentors.
                                     </div>
                                 </div>
                             </div>
                             <div class="row mt16" name="demo_data_buttons">
                                 <div class="col-6">
                                     <button name="action_load_demo_data" type="object" string="Load Demo Data" class="btn-primary"/>
                                 </div>
                                 <div class="col-6">
                                     <button name="action_clear_demo_data" type="object" string="Clear Demo Data" class="btn-danger"/>
                                 </div>
                             </div>
                         </block>
                     </app>
                 </xpath>
             </field>
         </record>
     </data>
 </odoo>
