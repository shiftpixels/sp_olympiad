<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="mentor_verification_email_template" model="mail.template">
        <field name="name">Mentor Email Verification</field>
        <field name="model_id" ref="model_sp_olympiad_mentor"/>
        <field name="subject">Verify your mentor account</field>
        <field name="email_from">{{ (user.email_formatted or user.company_id.email_formatted or '') }}</field>
        <field name="email_to">{{ object.email }}</field>
        <field name="auto_delete" eval="False"/>
        <field name="body_html" type="html">
            <div>
                <p>Hello <t t-out="object.name"/>,</p>
                <p>Thank you for registering as a mentor.</p>
                <p>Please verify your email address by clicking the link below:</p>
                <p>
                    <a t-att-href="'%s/mentor/verify/%s' % (object.get_base_url(), object.verification_token)">
                        Verify Email
                    </a>
                </p>
                <p>This link expires in 24 hours.</p>
            </div>
        </field>
    </record>
</odoo>
