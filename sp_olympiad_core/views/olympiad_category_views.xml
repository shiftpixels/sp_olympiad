<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <record id="view_olympiad_category_list" model="ir.ui.view">
        <field name="name">sp_olympiad.category.list</field>
        <field name="model">sp_olympiad.category</field>
        <field name="arch" type="xml">
            <list string="Categories">
                <field name="sequence" widget="handle"/>
                <field name="name"/>
                <field name="code"/>
                <field name="active" widget="boolean_toggle"/>
            </list>
        </field>
    </record>

    <!-- Category Kanban View -->
    <record id="view_olympiad_category_kanban" model="ir.ui.view">
        <field name="name">sp_olympiad.category.kanban</field>
        <field name="model">sp_olympiad.category</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="active"/>
                <templates>
                    <t t-name="card">
                        <div class="oe_kanban_global_click d-flex align-items-center" style="width: 800px !important;">
                            <!-- Left: Image Box (Same size as Event Prefix Box) -->
                            <div class="d-flex align-items-center justify-content-center bg-light rounded me-3 overflow-hidden" 
                                 style="width: 70px; height: 70px; flex-shrink: 0; border: 1px solid #eee;">
                                <field name="image" widget="image" options="{'preview_image': 'image'}" style="width: 100%; height: 100%; object-fit: cover;"/>
                            </div>
                            
                            <!-- Right: Content -->
                            <div class="flex-grow-1">
                                <field name="active" invisible="1"/>
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title">
                                        <field name="name"/>
                                    </strong>
                                </div>
                                <div class="text-muted small">
                                    <field name="code"/>
                                </div>
                                <div class="mt-2">
                                    <t t-if="record.active &amp;&amp; record.active.raw_value">
                                        <span class="badge rounded-pill text-bg-success">Active</span>
                                    </t>
                                    <t t-if="record.active &amp;&amp; !record.active.raw_value">
                                        <span class="badge rounded-pill text-bg-danger">Passive</span>
                                    </t>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_olympiad_category_form" model="ir.ui.view">
        <field name="name">sp_olympiad.category.form</field>
        <field name="model">sp_olympiad.category</field>
        <field name="arch" type="xml">
            <form string="Category">
                <sheet>
                    <div class="d-flex align-items-start mb-4">
                        <field name="image" widget="image" class="m-0 me-4" style="width: 250px; height: 250px; object-fit: cover;" options="{'preview_image': 'image'}"/>
                        <div class="flex-grow-1">
                            <div class="oe_title mb-3">
                                <label for="name" class="oe_edit_only"/>
                                <h1 class="w-100"><field name="name" placeholder="e.g. Environmental Science"/></h1>
                            </div>
                            <group>
                                <group>
                                    <field name="code"/>
                                    <field name="sequence"/>
                                </group>
                                <group>
                                    <field name="active" widget="boolean_toggle"/>
                                </group>
                            </group>
                        </div>
                    </div>
                    <notebook>
                        <page string="Web Description" name="description">
                            <field name="description" placeholder="Write the description that will be shown on the website..."/>
                        </page>
                        <page string="Evaluation Criteria" name="criteria">
                            <field name="criteria" placeholder="Define the rules and evaluation criteria for this category..."/>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_olympiad_category" model="ir.actions.act_window">
        <field name="name">Categories</field>
        <field name="res_model">sp_olympiad.category</field>
        <field name="view_mode">kanban,list,form</field>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">
                Create a new Olympiad Category
            </p>
        </field>
    </record>
</odoo>
