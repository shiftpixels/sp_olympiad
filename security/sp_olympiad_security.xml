<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- Security category for Olympiad modules -->
    <record id="sp_olympiad_security_category" model="ir.module.category">
        <field name="name">Olympiad</field>
        <field name="description">Olympiad Management Access Rights</field>
        <field name="sequence">10</field>
    </record>

    <!-- Privilege record (Odoo 19+) -->
    <record id="privilege_sp_olympiad" model="res.groups.privilege">
        <field name="name">Olympiad Privilege</field>
        <field name="category_id" ref="sp_olympiad_security_category"/>
    </record>

    <!-- Group: Olympiad Admin - Full Access -->
    <record id="group_sp_olympiad_admin" model="res.groups">
        <field name="name">Olympiad Admin</field>
        <field name="privilege_id" ref="privilege_sp_olympiad"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="user_ids" eval="[(4, ref('base.user_root')), (4, ref('base.user_admin'))]"/>
        <field name="comment">Full access to all Olympiad features and settings.</field>
        <field name="sequence">10</field>
    </record>

    <!-- Group: Olympiad Staff - Operational Access (no settings) -->
    <record id="group_sp_olympiad_staff" model="res.groups">
        <field name="name">Olympiad Staff</field>
        <field name="privilege_id" ref="privilege_sp_olympiad"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Operational access to Olympiad events and projects, but no system settings.</field>
        <field name="sequence">20</field>
    </record>

    <!-- Group: Olympiad Mentor - Own Projects Only -->
    <record id="group_sp_olympiad_mentor" model="res.groups">
        <field name="name">Olympiad Mentor</field>
        <field name="privilege_id" ref="privilege_sp_olympiad"/>
        <field name="implied_ids" eval="[(4, ref('base.group_portal'))]"/>
        <field name="comment">Access to create and manage own projects and students only.</field>
        <field name="sequence">30</field>
    </record>

    <!-- Group: Olympiad Jury - Assigned Projects and Scoring -->
    <record id="group_sp_olympiad_jury" model="res.groups">
        <field name="name">Olympiad Jury</field>
        <field name="privilege_id" ref="privilege_sp_olympiad"/>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
        <field name="comment">Access to view assigned projects and submit scores only.</field>
        <field name="sequence">40</field>
    </record>

    <!-- Mentor Profile Access Rules -->
    <record id="access_sp_olympiad_mentor_user" model="ir.model.access">
        <field name="name">sp_olympiad.mentor.user</field>
        <field name="model_id" ref="model_sp_olympiad_mentor"/>
        <field name="group_id" ref="base.group_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="access_sp_olympiad_mentor_manager" model="ir.model.access">
        <field name="name">sp_olympiad.mentor.manager</field>
        <field name="model_id" ref="model_sp_olympiad_mentor"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_admin"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record id="access_sp_olympiad_mentor_self" model="ir.model.access">
        <field name="name">sp_olympiad.mentor.self</field>
        <field name="model_id" ref="model_sp_olympiad_mentor"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_mentor"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="rule_mentor_own_profile" model="ir.rule">
        <field name="name">Mentors can only see their own profile</field>
        <field name="model_id" ref="model_sp_olympiad_mentor"/>
        <field name="domain_force">[('user_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sp_olympiad.group_sp_olympiad_mentor'))]"/>
    </record>

    <!-- Project Access Rules -->
    <record id="access_sp_olympiad_project_user" model="ir.model.access">
        <field name="name">sp_olympiad.project.user</field>
        <field name="model_id" ref="model_sp_olympiad_project"/>
        <field name="group_id" ref="base.group_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="access_sp_olympiad_project_manager" model="ir.model.access">
        <field name="name">sp_olympiad.project.manager</field>
        <field name="model_id" ref="model_sp_olympiad_project"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_admin"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record id="access_sp_olympiad_project_mentor" model="ir.model.access">
        <field name="name">sp_olympiad.project.mentor</field>
        <field name="model_id" ref="model_sp_olympiad_project"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_mentor"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="access_sp_olympiad_project_staff" model="ir.model.access">
        <field name="name">sp_olympiad.project.staff</field>
        <field name="model_id" ref="model_sp_olympiad_project"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_staff"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="access_sp_olympiad_project_jury" model="ir.model.access">
        <field name="name">sp_olympiad.project.jury</field>
        <field name="model_id" ref="model_sp_olympiad_project"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_jury"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Student Access Rules -->
    <record id="access_sp_olympiad_student_user" model="ir.model.access">
        <field name="name">sp_olympiad.student.user</field>
        <field name="model_id" ref="model_sp_olympiad_student"/>
        <field name="group_id" ref="base.group_user"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="0"/>
        <field name="perm_create" eval="0"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="access_sp_olympiad_student_manager" model="ir.model.access">
        <field name="name">sp_olympiad.student.manager</field>
        <field name="model_id" ref="model_sp_olympiad_student"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_admin"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="1"/>
    </record>

    <record id="access_sp_olympiad_student_mentor" model="ir.model.access">
        <field name="name">sp_olympiad.student.mentor</field>
        <field name="model_id" ref="model_sp_olympiad_student"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_mentor"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <record id="access_sp_olympiad_student_staff" model="ir.model.access">
        <field name="name">sp_olympiad.student.staff</field>
        <field name="model_id" ref="model_sp_olympiad_student"/>
        <field name="group_id" ref="sp_olympiad.group_sp_olympiad_staff"/>
        <field name="perm_read" eval="1"/>
        <field name="perm_write" eval="1"/>
        <field name="perm_create" eval="1"/>
        <field name="perm_unlink" eval="0"/>
    </record>

    <!-- Mentor Own Projects Rule -->
    <record id="rule_mentor_own_projects" model="ir.rule">
        <field name="name">Mentors can only see their own projects</field>
        <field name="model_id" ref="model_sp_olympiad_project"/>
        <field name="domain_force">[('mentor_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sp_olympiad.group_sp_olympiad_mentor'))]"/>
    </record>

    <!-- Mentor Own Students Rule -->
    <record id="rule_mentor_own_students" model="ir.rule">
        <field name="name">Mentors can only see their own students</field>
        <field name="model_id" ref="model_sp_olympiad_student"/>
        <field name="domain_force">[('mentor_id', '=', user.id)]</field>
        <field name="groups" eval="[(4, ref('sp_olympiad.group_sp_olympiad_mentor'))]"/>
    </record>

</odoo>
